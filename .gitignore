# Build output (keep icons in repo; ignore packaged zips only)
dist/*.zip
dist/build/

# Generated icons are committed after first run; optional regen via scripts/generate_icons.js
# extension/icons/

# OS / editor cruft
.DS_Store
*.swp

# Node (only used by the packaging script; no deps required)
node_modules/

# Local secrets / config (never commit API keys or signing keys)
config.json
.env
*.local
keys/
private.pem
public.pem

# Pilot-only docs with license keys — share directly with clients, not via git
QUADRANTECH_TESTING.md
licenses/

# Stray Python artifacts from the removed V1 stack
.venv/
.pytest_cache/
__pycache__/
*.pyc
