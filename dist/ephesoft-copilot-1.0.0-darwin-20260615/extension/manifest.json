{
  "manifest_version": 3,
  "name": "Ephesoft Copilot",
  "version": "0.1.0",
  "description": "Lets the Ephesoft Copilot panel act on the active tab. Human always validates.",
  "permissions": [
    "activeTab",
    "scripting",
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "service_worker.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Ephesoft Copilot"
  }
}
